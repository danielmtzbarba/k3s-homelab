{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "Service & Dependency Health",
      "type": "row",
      "collapsed": false,
      "panels": [],
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Core Service",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "expr": "max(up{job=~\".*quant-engine.*core.*|.*core.*\"})", "refId": "A" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "color": "red", "text": "OFFLINE" },
                "1": { "color": "green", "text": "ONLINE" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Messaging Service",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "expr": "max(up{job=~\".*quant-engine.*messaging.*|.*messaging.*\"})", "refId": "A" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "color": "red", "text": "OFFLINE" },
                "1": { "color": "green", "text": "ONLINE" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Postgres / Supabase",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "targets": [
        { "expr": "max(core_db_connected)", "refId": "A" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "color": "red", "text": "OFFLINE" },
                "1": { "color": "green", "text": "ONLINE" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Meta API",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "expr": "max(messaging_meta_api_connected)", "refId": "A" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "color": "red", "text": "OFFLINE" },
                "1": { "color": "green", "text": "ONLINE" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Webhook Parse Failures (1h)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        { "expr": "sum(rate(messaging_webhook_parse_failures_total[1h]))", "legendFormat": "parse failures", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Core 5xx Error Rate (10m)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        { "expr": "sum(rate(core_http_5xx_errors_total[10m]))", "legendFormat": "core 5xx", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "title": "Application Logs (quant-engine-mt5)",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "targets": [
        { "expr": "{namespace=\"quant-engine-mt5\"}", "refId": "A" }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["quant-engine", "system"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Quant Engine System Overview",
  "version": 1
}

{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "Messaging Flow",
      "type": "row",
      "collapsed": false,
      "panels": [],
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Webhook Ingestion Rate (1h)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        { "expr": "sum(rate(messaging_webhook_received_total[1h])) by (event_type)", "legendFormat": "{{event_type}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Parse Failures (Last Hour)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        { "expr": "sum(rate(messaging_webhook_parse_failures_total[1h]))", "legendFormat": "parse failures", "refId": "A" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 4,
      "title": "Meta API",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "expr": "messaging_meta_api_connected", "refId": "A" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "color": "red", "text": "OFFLINE" },
                "1": { "color": "green", "text": "ONLINE" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Bot Tool Latency (p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(messaging_bot_tool_latency_seconds_bucket[5m])) by (le, tool_name))", "legendFormat": "{{tool_name}} p95", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Tool Popularity",
      "type": "bargauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "targets": [
        { "expr": "sum(messaging_bot_tool_usage_total) by (tool_name, status)", "legendFormat": "{{tool_name}} ({{status}})", "refId": "A" }
      ],
      "options": {
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 7,
      "title": "Messaging Logs (quant-engine-mt5)",
      "type": "logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "targets": [
        { "expr": "{namespace=\"quant-engine-mt5\"} |= `messaging`", "refId": "A" }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["quant-engine", "messaging"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Quant Engine Messaging Flow",
  "version": 1
}

PROJECT_ID="your-gcp-project-id"
POOL_ID="k3s-homelab"
PROVIDER_ID="k3s-server-1"

# Optional. Space-separated IAM members to re-bind after each secret is recreated.
# This is important because delete/create resets secret-level IAM bindings.
GCP_SECRET_ACCESSORS="principal://iam.googleapis.com/projects/123456789012/locations/global/workloadIdentityPools/k3s-homelab/subject/system:serviceaccount:external-secrets:eso-gcpsm"

# Mapping variables:
# - each GCP_SECRET_<NAME> defines the GCP Secret Manager secret ID
# - the matching <NAME> variable defines the secret value to upload

GCP_SECRET_TAILSCALE_OAUTH_CLIENT_ID="k3s-ts-oauth-client-id"
TAILSCALE_OAUTH_CLIENT_ID="your-tailscale-oauth-client-id"

GCP_SECRET_TAILSCALE_OAUTH_CLIENT_SECRET="k3s-ts-oauth-client-secret"
TAILSCALE_OAUTH_CLIENT_SECRET="your-tailscale-oauth-client-secret"

GCP_SECRET_GRAFANA_ADMIN_USER="k3s-grafana-admin-user"
GRAFANA_ADMIN_USER="admin"

GCP_SECRET_GRAFANA_ADMIN_PASSWORD="k3s-grafana-admin-password"
GRAFANA_ADMIN_PASSWORD="set-a-stable-grafana-admin-password"

GCP_SECRET_ALERTMANAGER_SLACK_WEBHOOK_URL="k3s-alertmanager-slack-webhook-url"
ALERTMANAGER_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

GCP_SECRET_QUANT_ENGINE_GHCR_DOCKERCONFIGJSON="k3s-quant-engine-ghcr-dockerconfigjson"
QUANT_ENGINE_GHCR_DOCKERCONFIGJSON='{"auths":{"ghcr.io":{"username":"YOUR_GH_USERNAME","password":"YOUR_GHCR_PAT","auth":"BASE64_USERNAME_COLON_PAT"}}}'

GCP_SECRET_QUANT_ENGINE_DEV_CORE_ENV="k3s-quant-engine-dev-core-env"
QUANT_ENGINE_DEV_CORE_ENV='{"CORE_DATABASE_URL":"postgresql+asyncpg://user:password@host:5432/dbname","CORE_ADMIN_TOKEN":"replace-dev-core-admin-token"}'

GCP_SECRET_QUANT_ENGINE_DEV_MESSAGING_ENV="k3s-quant-engine-dev-messaging-env"
QUANT_ENGINE_DEV_MESSAGING_ENV='{"MSG_WHATSAPP_API_TOKEN":"replace-dev-meta-api-token","MSG_WHATSAPP_AUTH_TOKEN":"replace-dev-whatsapp-auth-token","MSG_OPENAI_API_KEY":"replace-dev-openai-api-key"}'

GCP_SECRET_QUANT_ENGINE_PROD_CORE_ENV="k3s-quant-engine-prod-core-env"
QUANT_ENGINE_PROD_CORE_ENV='{"CORE_DATABASE_URL":"postgresql+asyncpg://user:password@host:5432/dbname","CORE_ADMIN_TOKEN":"replace-prod-core-admin-token"}'

GCP_SECRET_QUANT_ENGINE_PROD_MESSAGING_ENV="k3s-quant-engine-prod-messaging-env"
QUANT_ENGINE_PROD_MESSAGING_ENV='{"MSG_WHATSAPP_API_TOKEN":"replace-prod-meta-api-token","MSG_WHATSAPP_AUTH_TOKEN":"replace-prod-whatsapp-auth-token","MSG_OPENAI_API_KEY":"replace-prod-openai-api-key"}'

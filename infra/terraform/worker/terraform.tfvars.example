project_id          = "your-gcp-project-id"
region              = "europe-west3"
zone                = "europe-west3-a"
network_name        = "k3s-lab"
subnet_name         = "k3s-lab-subnet"
cluster_tag         = "k3s-node"
server_name         = "k3s-server-1"
workers = {
  "k3s-worker-1" = {
    internal_ip        = "10.10.0.3"
    node_labels        = ["homelab.danielmtz/workload-role=quant"]
    tailscale_hostname = "k3s-worker-1"
  }
  "k3s-worker-2" = {
    internal_ip        = "10.10.0.4"
    node_labels        = ["homelab.danielmtz/workload-role=web"]
    machine_type       = "e2-standard-4"
    tailscale_hostname = "k3s-worker-2"
  }
}
worker_tag          = "k3s-worker"
node_labels         = []
machine_type        = "e2-standard-2"
image_family        = "ubuntu-2404-lts-amd64"
image_project       = "ubuntu-os-cloud"
ssh_user            = "your-user"
ssh_public_key      = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA..."
boot_disk_size_gb   = 40
tailscale_enable    = true
tailscale_auth_key  = "tskey-..."
tailscale_accept_dns = false
k3s_cluster_token   = "replace-with-long-random-cluster-token"
